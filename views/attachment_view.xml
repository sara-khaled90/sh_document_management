<odoo>
    <data>
        <record id="attachment_form_view_inherit" model="ir.ui.view">
            <field name="name">attachment.form.view.inherit</field>
            <field name="model">ir.attachment</field>
            <field name="inherit_id" ref="base.view_attachment_form"/>
            <field name="arch" type="xml">
                <field name="type" position="before">
                    <field name="directory_id"/>
                    <field name="document_tags" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}"/>
                    <field name="shared_user_ids" widget="many2many_tags" options="{'no_create': True, 'no_create_edit': True}"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
